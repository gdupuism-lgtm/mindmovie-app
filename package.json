{
  "name": "eriorcenter-mindmovie",
  "version": "1.0.0",
  "description": "ERIORCENTER Mind Movie Widget",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac --universal",
    "build:all": "electron-builder --win --mac --x64"
  },
  "build": {
    "appId": "com.eriorcenter.mindmovie",
    "productName": "ERIORCENTER Mind Movie",
    "files": ["src/**/*", "assets/**/*"],
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "category": "public.app-category.lifestyle"
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
